{
  "required": true,
  "minVersion": "0.8",
  "package": "bigsir.toolholster.mixin",
  "compatibilityLevel": "JAVA_8",
  "mixins": [
    "ContainerInventoryMixin",
    "ItemStackMixin",
    "MenuAbstractMixin",
    "SlotAccessor",
    "player.PlayerMixin"
  ],
  "client": [
    "player.PlayerRemoteMixin",
    "player.PlayerMixinClient",
    "MobRendererPlayerMixin",
    "PacketHandlerClientMixin",
